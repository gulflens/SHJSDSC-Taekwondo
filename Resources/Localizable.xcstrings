          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Prohibited Conduct"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Comportements interdits"
          }
        }
      }
    },
