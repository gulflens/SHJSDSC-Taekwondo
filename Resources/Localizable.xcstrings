          }
        }
      }
    },
    "privacy.section.data_we_collect.body" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "نجمع المعلومات اللازمة لتشغيل النادي: اسم الرياضي وتاريخ الميلاد والجنسية، رقم الهوية أو جواز السفر، فصيلة الدم، جهات الاتصال للطوارئ، الفرع والمدرب، الحزام الحالي وسجل الترقيات، الوزن والطول وسجل الإصابات، نتائج الاختبارات البدنية والفنية والبومسي، نتائج المباريات والبطولات، ساعات النوم والمزاج والإرهاق، الأهداف وملاحظات المدرب، وصور الملف الشخصي عند توفرها."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "We collect the information needed to run the club: athlete full name, date of birth and nationality, Emirates ID or passport number, blood type, emergency contacts, branch and primary coach, current belt and grading history, weight, height, injury log, physical / technical / poomsae assessment scores, match and tournament results, sleep / mood / RPE wellness check-ins, goals and coach notes, and profile photos if uploaded."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nous collectons les informations nécessaires au club : nom complet, date de naissance et nationalité, ID Emirates ou passeport, groupe sanguin, contacts d'urgence, branche et coach, ceinture et historique de grades, poids, taille, journal des blessures, scores physiques / techniques / poomsae, résultats de matchs et tournois, sommeil / humeur / RPE, objectifs et notes du coach, et photos de profil."
          }
        }
      }
    },
    "privacy.section.data_we_collect.title" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "البيانات التي نجمعها"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Data we collect"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Données collectées"
          }
        }
      }
    },
    "privacy.section.how_we_use_it.body" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تُستخدم البيانات لإدارة الحضور وتخطيط التدريب وتتبع التقدم وتقييم الجاهزية للترقية وتسجيل الرياضيين في البطولات والإبلاغ عن النتائج للاتحادات المعتمدة (مثل اتحاد الإمارات للتايكوندو). لا نستخدم البيانات لأغراض إعلانية أو نبيعها لطرف ثالث."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Your data is used to manage attendance, plan training, track progress, evaluate grading readiness, register athletes for tournaments, and report results to sanctioning bodies (e.g. UAE TKD Federation). We do not use it for advertising and we never sell data to third parties."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les données servent à gérer la présence, planifier l'entraînement, suivre la progression, évaluer l'aptitude au passage de grade, inscrire les athlètes aux tournois et déclarer les résultats aux fédérations. Aucun usage publicitaire, aucune revente."
          }
        }
      }
    },
    "privacy.section.how_we_use_it.title" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "كيف نستخدم البيانات"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "How we use it"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Utilisation des données"
          }
        }
      }
    },
    "privacy.section.media.body" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "لا يستخدم النادي صور الرياضي خارج التطبيق إلا بعد موافقة صريحة على \"حقوق الصورة\" في ملف الرياضي. يمكن إلغاء هذه الموافقة في أي وقت، وستتوقف المشاركة المستقبلية فوراً."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The club only uses an athlete's photo outside the app after explicit \"image rights\" consent on the athlete's profile. Consent can be revoked at any time and future external use stops immediately."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le club n'utilise les photos en dehors de l'app qu'après le consentement explicite « droit à l'image » sur la fiche athlète. Ce consentement est révocable à tout moment."
          }
        }
      }
    },
    "privacy.section.media.title" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "حقوق الصورة"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Photos & video"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Photos et vidéo"
          }
        }
      }
    },
    "privacy.section.minors.body" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "غالبية الرياضيين قاصرون. يُنشئ ملف الرياضي وموافقاته (حقوق الصورة، إذن السفر، اللياقة للتدريب) أحد الوالدين أو وصي قانوني عبر التطبيق أو من خلال إدارة النادي. يحق لولي الأمر سحب الموافقة في أي وقت بمراجعة المسؤول."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Most athletes are minors. An athlete's record and the related consents (image rights, travel permission, fit-to-train) are created by a parent or legal guardian via the app or by club administration. Guardians may withdraw consent at any time by contacting club administration."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La plupart des athlètes sont mineurs. La fiche et les consentements (droit à l'image, autorisation de voyage, aptitude à l'entraînement) sont créés par un parent ou tuteur légal. Le consentement peut être retiré à tout moment auprès de l'administration."
          }
        }
      }
    },
    "privacy.section.minors.title" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "القاصرون وموافقة الوالدين"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Minors & parental consent"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mineurs et consentement parental"
          }
        }
      }
    },
    "privacy.section.retention.body" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تُحفظ بيانات الرياضي طوال فترة عضويته في النادي. عند انتهاء العضوية تُؤرشف البيانات لمدة سنتين لأغراض تاريخية (سجل الترقيات والميداليات) ثم تُجهَّل أو تُحذف ما لم يطلب ولي الأمر حذفها فوراً."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Athlete data is kept for the duration of club membership. When membership ends the records are archived for two years for historical reference (grading history, medals) then anonymised or deleted, unless the guardian requests immediate deletion."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les données sont conservées pendant l'adhésion. À la fin de celle-ci, elles sont archivées deux ans (historique grades / médailles) puis anonymisées ou supprimées, sauf demande de suppression immédiate."
          }
        }
      }
    },
    "privacy.section.retention.title" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "مدة الاحتفاظ"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "How long we keep it"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Durée de conservation"
          }
        }
      }
    },
    "privacy.section.sharing.body" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تقتصر صلاحية الاطلاع على المدربين والإدارة في النادي. يستطيع الوالدان رؤية بيانات أبنائهم فقط، ويرى الرياضي ملفه الخاص. عند المشاركة في بطولة، تُرسل البيانات اللازمة للتسجيل (الاسم، الفئة العمرية، الوزن) إلى الجهة المنظمة للحدث وفقاً للوائحها."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Inside the club, only coaches and administrators see athlete records — and only for athletes assigned to them. Parents see only their own children. Athletes see only their own profile. When entering a tournament, the data required by the organiser (name, age division, weight) is shared with that body per its registration rules."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Au sein du club, seuls coachs et administrateurs voient les fiches — et uniquement celles qui leur sont assignées. Les parents ne voient que leurs enfants. Les athlètes ne voient que leur propre profil. Lors d'une inscription à un tournoi, les données requises (nom, division d'âge, poids) sont partagées avec l'organisateur."
          }
        }
      }
    },
    "privacy.section.sharing.title" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "من يطّلع على البيانات"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Who sees what"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Qui voit quoi"
          }
        }
      }
    },
    "privacy.section.storage.body" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تُخزَّن البيانات في خوادم Supabase المشفّرة أثناء الإرسال وأثناء التخزين، مع تطبيق صلاحيات صارمة على مستوى الصفوف لمنع الاطلاع غير المصرح به. تُحفظ صور الملف الشخصي في تخزين منفصل ومحمي بالصلاحيات نفسها."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Data is stored on Supabase servers, encrypted in transit and at rest, with row-level security ensuring users only retrieve rows they're authorised to see. Profile photos live in a dedicated storage bucket protected by the same access rules."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les données sont stockées sur Supabase, chiffrées en transit et au repos, avec une sécurité par ligne empêchant tout accès non autorisé. Les photos sont dans un dépôt dédié protégé par les mêmes règles."
          }
        }
      }
    },
    "privacy.section.storage.title" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "أين تُحفظ البيانات"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Where it lives"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Où sont stockées les données"
          }
        }
      }
    },
    "privacy.section.your_rights.body" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يحق لك في أي وقت طلب نسخة من بياناتك (يتوفر زر \"تصدير بياناتي\" في صفحة الإعدادات)، أو طلب تصحيحها، أو طلب حذفها. تتم معالجة طلبات الحذف خلال 30 يوماً مع الاحتفاظ بأي سجلات قانونية مطلوبة (مثل سجلات السلامة)."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "You can request a copy of your data at any time (the \"Export my data\" button in Settings does this), ask for corrections, or request deletion. Deletion requests are processed within 30 days, except for records the club is legally required to retain (e.g. safety logs)."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
