    "poomsae.score_help" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "الدقة = الوقفات/الحركات/التسلسل. الأداء = القوة/السرعة/الإيقاع. التعبير = الكيهاب والتركيز."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Accuracy = stances/techniques/sequence. Presentation = power/speed/rhythm. Expression = kihap + focus."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Précision = postures/techniques/séquence. Présentation = puissance/vitesse/rythme. Expression = kihap et concentration."
          }
        }
      }
    },
