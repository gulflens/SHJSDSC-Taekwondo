    "dev.sync.description" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يدفع الفروع الأربعة المُكوَّنة مسبقًا (الرحمانية، النصرية، النوف، المنطقة الصناعية ١٨) مع جميع السجلات الفرعية (المرافق، الساعات، البرامج، الأسعار، المخزون، الامتثال، الوسائط، الروابط الاجتماعية، الحماية، المعالم) إلى قاعدة البيانات المتصلة حاليًا."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pushes the four pre-seeded branches (Al Rahmania, Al Nasserya, Al Nouf, Industrial 18) and all of their profile sub-records (facility, hours, programs, pricing, inventory, compliance, media, social links, safeguarding, milestones) to the currently-connected database."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pousse les quatre filiales pré-configurées (Al Rahmania, Al Nasserya, Al Nouf, Industrial 18) et tous leurs sous-enregistrements de profil (installation, horaires, programmes, tarifs, inventaire, conformité, médias, liens sociaux, protection, jalons) vers la base de données actuellement connectée."
          }
        }
      }
    },
