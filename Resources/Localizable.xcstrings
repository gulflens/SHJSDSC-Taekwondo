    "about.app_title" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "حول تطبيق SHJSDSC للتايكوندو"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "About SHJSDSC Taekwondo"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "À propos de SHJSDSC Taekwondo"
          }
        }
      }
    },
    "about.contact_body" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "هل لديك أسئلة أو ملاحظات أو أفكار حول التطبيق؟ يسعدنا تواصلك معنا."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Questions, feedback, or ideas for the app? We'd love to hear from you."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Des questions, des commentaires ou des idées pour l'application ? N'hésitez pas à nous écrire."
          }
        }
      }
    },
    "about.contact_title" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تواصل معنا"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Get in Touch"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nous contacter"
          }
        }
      }
    },
    "about.section.app.body" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تطبيق SHJSDSC للتايكوندو هو التطبيق الرسمي لإدارة برنامج التايكوندو في نادي الشارقة لرياضات الدفاع عن النفس. يجمع سجلات اللاعبين والتدريب والترقيات والبطولات في مكان واحد للمدربين ومديري الفروع والعائلات."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "SHJSDSC Taekwondo is the official club management app for the Sharjah Self-Defense Sports Club Taekwondo program. It brings athlete records, training, grading, and competitions together in one place for coaches, branch managers, and families."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "SHJSDSC Taekwondo est l'application officielle de gestion du programme de Taekwondo du Sharjah Self-Defense Sports Club. Elle réunit les dossiers des athlètes, l'entraînement, les passages de grade et les compétitions en un seul endroit pour les entraîneurs, les responsables de branche et les familles."
          }
        }
      }
    },
    "about.section.app.title" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "التطبيق"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The App"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "L'application"
          }
        }
      }
    },
    "about.section.club.body" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يدير نادي الشارقة لرياضات الدفاع عن النفس تدريب التايكوندو في أربعة فروع في دولة الإمارات العربية المتحدة. يطوّر النادي اللاعبين من الحزام الأبيض وحتى المسارات الوطنية والأولمبية بإشراف مدربين معتمدين."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The Sharjah Self-Defense Sports Club runs Taekwondo training across four branches in the United Arab Emirates. The club develops athletes from white belt through national and Olympic pathways, guided by certified coaches."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le Sharjah Self-Defense Sports Club propose un entraînement de Taekwondo dans quatre branches aux Émirats arabes unis. Le club développe les athlètes de la ceinture blanche jusqu'aux parcours nationaux et olympiques, encadrés par des entraîneurs certifiés."
          }
        }
      }
    },
    "about.section.club.title" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "النادي"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The Club"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le club"
          }
        }
      }
    },
    "about.section.features.body" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تابع ملفات اللاعبين وأداءهم، وجدوِل الحصص وأدِرها، وأدِر ترقيات الأحزمة والشهادات، وسجّل في البطولات، وتابع نتائج المباريات المباشرة — كل ذلك بالعربية والإنجليزية مع دعم كامل للكتابة من اليمين إلى اليسار."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Track athlete profiles and performance, schedule and run classes, manage belt grading and certificates, register for tournaments, and follow live match results — all in English and Arabic with full right-to-left support."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Suivez les profils et les performances des athlètes, planifiez et animez les cours, gérez les passages de grade et les certificats, inscrivez-vous aux tournois et suivez les résultats des matchs en direct — le tout en anglais et en arabe avec une prise en charge complète de l'écriture de droite à gauche."
          }
        }
      }
    },
    "about.section.features.title" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ما يمكنك فعله"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "What You Can Do"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ce que vous pouvez faire"
          }
        }
      }
    },
    "about.section.team.body" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تطبيق SHJSDSC للتايكوندو من تصميم وتطوير Gulf Lens Studio، التي تبني برمجيات احترافية ومركّزة للمؤسسات الرياضية في المنطقة."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "SHJSDSC Taekwondo is designed and developed by Gulf Lens Studio, building focused, premium software for sports organisations in the region."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "SHJSDSC Taekwondo est conçu et développé par Gulf Lens Studio, qui crée des logiciels premium et ciblés pour les organisations sportives de la région."
          }
        }
      }
    },
    "about.section.team.title" : {
