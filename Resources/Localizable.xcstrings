    "privacy.contact_body" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "لأي سؤال حول الخصوصية أو لطلب الاطلاع على بياناتك أو حذفها، تواصل مع مسؤول حماية البيانات في النادي عبر:"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "For any privacy question, or to request access to or deletion of your data, contact the club's data protection officer at:"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pour toute question relative à la confidentialité ou pour demander l'accès / la suppression de vos données, contactez notre délégué à la protection des données :"
          }
        }
      }
    },
    "privacy.contact_title" : {
