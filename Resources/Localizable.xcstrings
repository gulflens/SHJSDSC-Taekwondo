    "license.section.app.body" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تطبيق SHJSDSC للتايكوندو — بما في ذلك شيفرته المصدرية وتصميمه ومحتواه — ملكية حصرية لـ Gulf Lens Studio ونادي الشارقة لرياضات الدفاع عن النفس. وهو مرخّص للاستخدام من قبل النادي وأعضائه المخوّلين، ولا يجوز نسخه أو إعادة توزيعه أو إجراء هندسة عكسية له."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The SHJSDSC Taekwondo app — its source code, design, and content — is the proprietary property of Gulf Lens Studio and the Sharjah Self-Defense Sports Club. It is licensed for use by the club and its authorised members and may not be copied, redistributed, or reverse-engineered."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "L'application SHJSDSC Taekwondo — son code source, sa conception et son contenu — est la propriété exclusive de Gulf Lens Studio et du Sharjah Self-Defense Sports Club. Elle est concédée sous licence pour une utilisation par le club et ses membres autorisés et ne peut être copiée, redistribuée ni soumise à de l'ingénierie inverse."
          }
        }
      }
    },
