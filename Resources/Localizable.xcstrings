    "license.section.frameworks.body" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "بُني هذا التطبيق باستخدام إطار SwiftUI وأطر منصة Apple، ويستخدم رموز SF Symbols. تظل هذه الأطر والرموز ملكًا لشركة Apple Inc. وتُستخدم وفقًا لشروط برنامج Apple Developer."
