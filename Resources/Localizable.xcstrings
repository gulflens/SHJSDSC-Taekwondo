    "settings.wipe_local_help" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يلغي الإشعارات المُدرجة، يمسح المستخدم المحفوظ، يحذف الصور المخزنة، ويسجل الخروج. أغلق التطبيق ثم افتحه لتبديل الواجهة الخلفية."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cancels queued notifications, clears the remembered user, removes cached photos and signs out. Force-quit + reopen to swap backends."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Annule les notifications, oublie l'utilisateur, supprime les photos en cache et déconnecte. Forcez la fermeture puis rouvrez pour changer de backend."
          }
        }
      }
    },
