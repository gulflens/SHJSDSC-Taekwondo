    "sync.explainer" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يحتفظ التطبيق بنسخة محلية من بياناتك الأساسية لتبقى الشاشات الرئيسية متاحة دون اتصال. يجلب التحديث أحدث نسخة من الخادم."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The app keeps a local copy of your core data so the main screens stay available without a connection. Refreshing pulls the newest version from the server."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "L'application conserve une copie locale de vos données essentielles afin que les écrans principaux restent accessibles sans connexion. L'actualisation récupère la version la plus récente depuis le serveur."
          }
        }
      }
    },
