        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Touchez « Obtenir le modèle » pour enregistrer le CSV depuis l'application, complétez-le (un athlète par ligne), puis revenez ici et choisissez le fichier. Excel et Numbers exportent en CSV en un clic."
          }
        }
      }
    },
