          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Last updated: May 2026"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dernière mise à jour : mai 2026"
          }
        }
      }
    },
    "terms.section.acceptance.body" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "بإنشائك حسابًا أو باستخدامك تطبيق SHJSDSC للتايكوندو، فإنك توافق على شروط الاستخدام هذه. إذا كنت لا توافق عليها، فيرجى عدم استخدام التطبيق."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "By creating an account or using the SHJSDSC Taekwondo app, you agree to these Terms of Use. If you do not agree, please do not use the app."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "En créant un compte ou en utilisant l'application SHJSDSC Taekwondo, vous acceptez ces conditions d'utilisation. Si vous ne les acceptez pas, veuillez ne pas utiliser l'application."
          }
        }
      }
    },
    "terms.section.acceptance.title" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "قبول الشروط"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Acceptance of Terms"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Acceptation des conditions"
          }
        }
      }
    },
    "terms.section.availability.body" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "نعمل على إبقاء التطبيق موثوقًا، إلا أنه يُقدَّم على أساس \"حسب توفّره\". قد تتغير الميزات، وقد يُقطع الوصول لأغراض الصيانة أو التحديثات أو لأسباب خارجة عن إرادتنا."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "We work to keep the app reliable, but it is provided on an \"as available\" basis. Features may change, and access may be interrupted for maintenance, updates, or reasons beyond our control."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nous nous efforçons de maintenir la fiabilité de l'application, mais celle-ci est fournie « telle que disponible ». Les fonctionnalités peuvent évoluer et l'accès peut être interrompu pour maintenance, mises à jour ou pour des raisons indépendantes de notre volonté."
          }
        }
      }
    },
    "terms.section.availability.title" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "توفّر الخدمة"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Service Availability"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Disponibilité du service"
          }
        }
      }
    },
    "terms.section.changes.body" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "قد نحدّث هذه الشروط مع تطور التطبيق. استمرارك في الاستخدام بعد أي تحديث يعني موافقتك على الشروط المعدّلة. سيتم إبراز التغييرات الجوهرية داخل التطبيق."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "We may update these Terms as the app evolves. Continued use after an update means you accept the revised Terms. Significant changes will be highlighted in the app."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nous pouvons mettre à jour ces conditions à mesure que l'application évolue. Toute utilisation continue après une mise à jour vaut acceptation des conditions révisées. Les modifications importantes seront signalées dans l'application."
          }
        }
      }
    },
    "terms.section.changes.title" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "التغييرات على هذه الشروط"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Changes to These Terms"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Modifications des présentes conditions"
          }
        }
      }
    },
    "terms.section.eligibility.body" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تصدر الحسابات من قبل النادي للمدربين ومديري الفروع والإداريين وأولياء أمور اللاعبين المسجلين. أنت مسؤول عن الحفاظ على سرية بيانات تسجيل دخولك وعن جميع الأنشطة التي تتم عبر حسابك. تتم إدارة الحسابات المتعلقة بالقاصرين من قبل ولي الأمر أو الوصي أو موظفي النادي المخوّلين."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Accounts are issued by the club to coaches, branch managers, administrators, and the parents or guardians of enrolled athletes. You are responsible for keeping your login credentials secure and for all activity under your account. Accounts involving minors are managed by a parent, guardian, or authorised club staff."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les comptes sont délivrés par le club aux entraîneurs, responsables de branche, administrateurs et aux parents ou tuteurs des athlètes inscrits. Vous êtes responsable de la confidentialité de vos identifiants et de toute activité effectuée sous votre compte. Les comptes concernant des mineurs sont gérés par un parent, un tuteur ou un membre autorisé du personnel du club."
          }
        }
      }
    },
    "terms.section.eligibility.title" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "الأهلية والحسابات"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Eligibility & Accounts"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Admissibilité et comptes"
          }
        }
      }
    },
    "terms.section.liability.body" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يدعم التطبيق عمليات النادي لكنه لا يحل محل التقدير المهني للتدريب أو الرعاية الطبية أو السلامة. إلى الحد الذي يسمح به القانون، لا يتحمل النادي ولا Gulf Lens Studio المسؤولية عن أي خسائر تنشأ عن استخدام التطبيق."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The app supports club operations but does not replace professional coaching, medical, or safety judgement. To the extent permitted by law, the club and Gulf Lens Studio are not liable for losses arising from use of the app."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "L'application accompagne les activités du club mais ne remplace pas le jugement professionnel en matière d'entraînement, de santé ou de sécurité. Dans les limites permises par la loi, le club et Gulf Lens Studio ne sont pas responsables des pertes résultant de l'utilisation de l'application."
          }
        }
      }
    },
    "terms.section.liability.title" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "إخلاء المسؤولية"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Disclaimers & Liability"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Avertissements et responsabilité"
          }
        }
      }
    },
    "terms.section.member_data.body" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "المعلومات التي تدخلها — سجلات اللاعبين والدرجات والملاحظات والوسائط — تعود ملكيتها للنادي وللأعضاء المعنيين بها. أضف فقط المحتوى المخوَّل لك بمشاركته، وتعامل مع المعلومات الشخصية للاعبين بمسؤولية. راجع سياسة الخصوصية لمزيد من التفاصيل."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Information you enter — athlete records, scores, notes, and media — belongs to the club and the members it concerns. Only add content you are authorised to share, and handle athletes' personal information responsibly. See the Privacy Policy for details."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les informations que vous saisissez — dossiers des athlètes, scores, notes et médias — appartiennent au club et aux membres concernés. N'ajoutez que du contenu que vous êtes autorisé à partager et traitez les informations personnelles des athlètes de manière responsable. Consultez la politique de confidentialité pour plus de détails."
          }
        }
      }
    },
    "terms.section.member_data.title" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "بيانات الأعضاء والمحتوى"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Member Data & Content"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Données et contenu des membres"
          }
        }
      }
    },
    "terms.section.permitted_use.body" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يُوفَّر التطبيق لإدارة أنشطة النادي — سجلات اللاعبين والتدريب والترقيات والبطولات. استخدمه لهذه الأغراض فقط، وبما يتوافق مع دورك والصلاحيات الممنوحة لك من النادي."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The app is provided for managing club activities — athlete records, training, grading, and competitions. Use it only for these purposes, in line with your role and the permissions granted to you by the club."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "L'application est fournie pour gérer les activités du club — dossiers des athlètes, entraînement, passages de grade et compétitions. Utilisez-la uniquement à ces fins, conformément à votre rôle et aux autorisations que le club vous a accordées."
          }
        }
      }
    },
    "terms.section.permitted_use.title" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "الاستخدام المسموح به"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Permitted Use"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Utilisation autorisée"
          }
        }
      }
    },
    "terms.section.prohibited.body" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "لا تحاول الوصول إلى بيانات خارج نطاق دورك المحدد، أو مشاركة حسابك، أو رفع محتوى غير قانوني أو ضار، أو تعطيل الخدمة، أو استخدام التطبيق للتحرش بالآخرين. يحق للنادي تعليق الحسابات التي تنتهك هذه الشروط."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Do not attempt to access data outside your assigned role, share your account, upload unlawful or harmful content, disrupt the service, or use the app to harass others. The club may suspend accounts that violate these terms."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "N'essayez pas d'accéder à des données en dehors de votre rôle attribué, de partager votre compte, de téléverser du contenu illégal ou nuisible, de perturber le service ou d'utiliser l'application pour harceler autrui. Le club peut suspendre les comptes qui enfreignent ces conditions."
          }
        }
      }
    },
    "terms.section.prohibited.title" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
