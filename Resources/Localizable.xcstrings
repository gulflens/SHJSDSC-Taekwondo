    "offline.demo_note" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يعمل التطبيق حاليًا على بيانات تجريبية مخزّنة على الجهاز، وهي متاحة دائمًا دون اتصال. يصبح وضع عدم الاتصال فعّالًا بالكامل عند الاتصال بالخادم السحابي."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This app is currently running on on-device demo data, which is always available offline. Offline Mode takes full effect when connected to the cloud backend."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cette application fonctionne actuellement avec des données de démonstration stockées sur l'appareil, toujours disponibles hors ligne. Le mode hors ligne prend pleinement effet lorsqu'elle est connectée au backend cloud."
          }
        }
      }
    },
    "offline.error.unavailable" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تتطلب هذه العملية اتصالاً بالإنترنت. أوقف وضع عدم الاتصال وحاول مرة أخرى."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This action needs a connection. Turn off Offline Mode and try again."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cette action nécessite une connexion. Désactivez le mode hors ligne et réessayez."
          }
        }
      }
    },
    "offline.explainer" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "عند تشغيل وضع عدم الاتصال، يعرض التطبيق القوائم الرئيسية من ذاكرته المحلية ويوقف التغييرات التي تتطلب الخادم. يُستأنف الحفظ بمجرد إيقافه وإعادة الاتصال."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "When Offline Mode is on, the app serves the main lists from its local cache and pauses changes that need the server. Saving resumes once you turn it off and reconnect."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lorsque le mode hors ligne est activé, l'application affiche les listes principales depuis son cache local et suspend les modifications nécessitant le serveur. L'enregistrement reprend dès que vous le désactivez et vous reconnectez."
          }
        }
      }
    },
